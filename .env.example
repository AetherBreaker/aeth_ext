# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Alert email account password (see settings.BaseSettings.alerts_email_pwd)
ALERTS_EMAIL_PWD=

# SFTPyPI publish credentials (basic auth). Used by `poe release` to publish
# to the SFTPyPI index. These are separate from the global UV_PUBLISH_TOKEN,
# which is reserved for public PyPI.
UV_INDEX_SFTPYPI_USERNAME=
UV_INDEX_SFTPYPI_PASSWORD=
