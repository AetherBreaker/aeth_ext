{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Project",
            "type": "debugpy",
            "request": "launch",
            "justMyCode": false,
            "program": "${workspaceFolder}\\src\\",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/testing.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\src",
                "PYTHONPYCACHEPREFIX": "${workspaceFolder}\\PYCACHE",
                "PYTHONUNBUFFERED": "1",
                "GOOGLE_API_KEY_FILE": "${workspaceFolder}\\secrets\\db-key.json",
                "SFT_WEBSITE_CREDS_FILE": "${workspaceFolder}\\secrets\\sft_creds.json",
                "SAS_FTP_CREDS_FILE": "${workspaceFolder}\\secrets\\sas_ftp_creds.json",
                "RYO_FTP_CREDS_FILE": "${workspaceFolder}\\secrets\\ryo_ftp_creds.json"
            }
        },
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/testing.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\src",
                "PYTHONPYCACHEPREFIX": "${workspaceFolder}\\PYCACHE",
                "PYTHONUNBUFFERED": "1",
                "GOOGLE_API_KEY_FILE": "${workspaceFolder}\\secrets\\db-key.json",
                "SFT_WEBSITE_CREDS_FILE": "${workspaceFolder}\\secrets\\sft_creds.json",
                "SAS_FTP_CREDS_FILE": "${workspaceFolder}\\secrets\\sas_ftp_creds.json",
                "RYO_FTP_CREDS_FILE": "${workspaceFolder}\\secrets\\ryo_ftp_creds.json"
            }
        }
    ]
}
