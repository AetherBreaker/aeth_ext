{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/testing.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\src",
                "PYTHONPYCACHEPREFIX": "${workspaceFolder}\\__pycache__",
                "PYTHONUNBUFFERED": "1",
                "PYTHONSAFEPATH": "1"
            }
        },
        {
            "name": "Current File (as module)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/debug_as_module.py",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/testing.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}\\src",
                "PYTHONPYCACHEPREFIX": "${workspaceFolder}\\__pycache__",
                "PYTHONUNBUFFERED": "1",
                "PYTHONSAFEPATH": "1"
            }
        }
    ]
}
